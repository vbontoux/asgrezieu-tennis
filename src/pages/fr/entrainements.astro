---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../components/animations/ScrollReveal.astro';

const locale = 'fr';

// Lecture du planning depuis le fichier Markdown géré par Tina CMS
const entrainementsModules = import.meta.glob('../../../content/entrainements/fr.md', { eager: true });
const data = (Object.values(entrainementsModules)[0] as any)?.frontmatter ?? { coachs: [], planning: [] };
const coachs = (data.coachs ?? []).map((c: any) => ({ name: c.nom, role: 'Coach', diplome: c.diplome }));

// Conversion du tableau planning[] en objet { jour: creneaux[] }
const planningMap = Object.fromEntries(
  (data.planning ?? []).map((p: any) => [p.jour, p.creneaux ?? []])
);

const days = ['lundi', 'mardi', 'mercredi', 'jeudi', 'vendredi', 'samedi'] as const;
const dayLabels = { lundi: 'LUNDI', mardi: 'MARDI', mercredi: 'MERCREDI', jeudi: 'JEUDI', vendredi: 'VENDREDI', samedi: 'SAMEDI' };
---

<BaseLayout
  title="Entraînements - Grézieu Tennis"
  description="Coachs et créneaux d'entraînement du Tennis Club de Grézieu-la-Varenne."
  locale={locale}
  currentPath="/fr/entrainements"
>
  <div class="page-dark">
    <!-- Coachs -->
    <section class="section">
      <div class="container">
        <ScrollReveal animation="fade-in">
          <div class="section-header">
            <h1>Coachs</h1>
            <div class="title-separator"></div>
          </div>
        </ScrollReveal>
        <div class="coachs-grid">
          {coachs.map((coach: any, i: number) => (
            <ScrollReveal animation="scale-in" delay={((i + 1) as 1 | 2 | 3 | 4)}>
              <div class="coach-card card-hover">
                <h2 class="coach-name">{coach.name}</h2>
                <p class="coach-role">{coach.role}</p>
                {coach.diplome && <span class="coach-badge">{coach.diplome}</span>}
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>

    <!-- Planning -->
    <section class="section">
      <div class="container">
        <ScrollReveal animation="fade-in">
          <div class="section-header">
            <h2 class="section-title-white">Créneaux d'Entraînement</h2>
            <div class="title-separator"></div>
          </div>
        </ScrollReveal>

        <ScrollReveal animation="slide-up">
          <div class="planning-grid">
            {days.map(day => (
              <div class="day-column">
                <h3 class="day-title">{dayLabels[day]}</h3>
                <div class="slots">
                  {(planningMap[day] ?? []).map((slot: any) => (
                    <div class:list={['slot-card', { 'slot-alt': (slot as any).alt }]}>
                      <span class="slot-time">{slot.time}</span>
                      <span class="slot-label">{slot.label}</span>
                      <span class="slot-coach">{slot.coach}</span>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </ScrollReveal>
      </div>
    </section>
  </div>
</BaseLayout>

<style is:global>body:has(.page-dark){background-color:#1e2a4a;}</style>
<style>
  .page-dark { background-color: #1e2a4a; padding-top: var(--spacing-xl); padding-bottom: var(--spacing-3xl); }
  .section { padding: var(--spacing-2xl) 0; }
  .section-header { text-align: center; margin-bottom: var(--spacing-2xl); }
  .section-header h1, .section-title-white { color: #ffffff; font-size: clamp(28px, 4vw, 44px); font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin-bottom: var(--spacing-md); }
  .title-separator { width: 80px; height: 3px; background-color: #c9a84c; margin: 0 auto; }

  .coachs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: var(--spacing-lg); max-width: 900px; margin: 0 auto; }
  .coach-card { text-align: center; padding: var(--spacing-xl); background: #ffffff; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,.2); }
  .coach-name { font-size: var(--font-size-lg); font-weight: 700; color: #1e2a4a; margin-bottom: var(--spacing-xs); }
  .coach-role { font-size: var(--font-size-sm); color: var(--color-text-light); margin-bottom: var(--spacing-sm); }
  .coach-badge { display: inline-block; padding: 4px 12px; background: var(--color-primary); color: #ffffff; font-size: 11px; font-weight: 700; border-radius: 50px; text-transform: uppercase; }

  .planning-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: var(--spacing-sm); overflow-x: auto; }
  .day-column { min-width: 150px; }
  .day-title { text-align: center; font-size: var(--font-size-sm); font-weight: 800; color: #ffffff; padding: var(--spacing-sm); margin-bottom: var(--spacing-sm); border-bottom: 2px solid rgba(255,255,255,.2); }
  .slots { display: flex; flex-direction: column; gap: var(--spacing-xs); }
  .slot-card { background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15); border-radius: 8px; padding: var(--spacing-sm); text-align: center; transition: background 200ms ease, transform 200ms ease; }
  .slot-card:hover { background: rgba(255,255,255,.14); transform: translateY(-2px); }
  .slot-alt { background: rgba(201,168,76,.15); border-color: rgba(201,168,76,.3); }
  .slot-time { display: block; font-size: 13px; font-weight: 700; color: #ffffff; margin-bottom: 4px; }
  .slot-label { display: block; font-size: 11px; color: rgba(255,255,255,.85); font-weight: 500; margin-bottom: 2px; }
  .slot-coach { display: block; font-size: 10px; color: rgba(255,255,255,.5); font-style: italic; }

  @media (max-width: 768px) { .planning-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .planning-grid { grid-template-columns: 1fr; } }
</style>
