---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../components/animations/ScrollReveal.astro';
import { asset } from '../../i18n/utils';

const locale = 'fr';

const actuModules = import.meta.glob('../../../content/actualites/fr/*.md', { eager: true });
const actus = (Object.values(actuModules) as any[])
  .map(a => a.frontmatter)
  .filter((a: any) => a.publie !== false);
const heroActu = actus[0];
---

<BaseLayout
  title="Actualités et Événements - Grézieu Tennis"
  description="Actualités du Tennis Club de Grézieu-la-Varenne. Tournois, événements et nouveautés."
  locale={locale}
  currentPath="/fr/actualites"
>
  <!-- Hero Tournoi — plein écran, engageant -->
  {heroActu && (
  <section class="tournoi-hero">
    <div class="tournoi-bg">
      <img src={asset(heroActu.image ?? '/images/hero-courts.jpg')} alt="" aria-hidden="true" />
    </div>
    <div class="tournoi-overlay"></div>
    <div class="tournoi-content">
      <ScrollReveal animation="fade-in">
        {heroActu.tag && <span class="tournoi-tag">{heroActu.tag}</span>}
        <h1>{heroActu.titre}</h1>
        {heroActu.dates && <p class="tournoi-dates">{heroActu.dates}</p>}
        {heroActu.description && <p class="tournoi-desc">{heroActu.description}</p>}
        {heroActu.lien && (
          <a href={heroActu.lien} target="_blank" rel="noopener noreferrer" class="tournoi-btn">
            {heroActu.lienLabel ?? 'En savoir plus →'}
          </a>
        )}
      </ScrollReveal>
    </div>
  </section>
  )}

  <!-- Section Location -->
  <section class="location-section">
    <div class="container">
      <ScrollReveal animation="slide-up">
        <div class="location-card">
          <div class="location-icon">🆕</div>
          <div class="location-body">
            <h2>Location de terrains ouverte à tous</h2>
            <p>Le Club ouvre désormais la location horaire de ses terrains aux <strong>non-adhérents et non-licenciés</strong> !</p>
            <a href="https://www.anybuddyapp.com/club-grezieu-tennis-as/reservation/tennis?activity=tennis" target="_blank" rel="noopener noreferrer" class="location-btn">
              Réserver sur Anybuddy →
            </a>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>

<style>
  /* Tournoi Hero — full width, immersif */
  .tournoi-hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .tournoi-bg {
    position: absolute;
    inset: 0;
  }

  .tournoi-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.4);
  }

  .tournoi-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(30, 42, 74, 0.3) 0%,
      rgba(30, 42, 74, 0.85) 100%
    );
  }

  .tournoi-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--spacing-3xl) var(--spacing-md);
    max-width: 700px;
  }

  .tournoi-tag {
    display: inline-block;
    padding: 6px 20px;
    background: rgba(201, 168, 76, 0.2);
    border: 1px solid #c9a84c;
    color: #c9a84c;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    border-radius: 50px;
    margin-bottom: var(--spacing-lg);
  }

  .tournoi-hero h1 {
    color: #ffffff;
    font-size: clamp(40px, 8vw, 72px);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: var(--spacing-md);
    line-height: 1;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  }

  .tournoi-dates {
    font-size: clamp(18px, 3vw, 28px);
    color: #c9a84c;
    font-weight: 700;
    margin-bottom: var(--spacing-lg);
    letter-spacing: 1px;
  }

  .tournoi-desc {
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
    margin-bottom: var(--spacing-xl);
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .tournoi-btn {
    display: inline-block;
    padding: 16px 40px;
    background: #c9a84c;
    color: #1e2a4a;
    font-size: var(--font-size-base);
    font-weight: 700;
    border-radius: 50px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: transform 250ms ease, box-shadow 250ms ease;
    box-shadow: 0 4px 20px rgba(201, 168, 76, 0.3);
  }

  .tournoi-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(201, 168, 76, 0.5);
    color: #1e2a4a;
  }

  /* Location section */
  .location-section {
    background: var(--color-dark);
    padding: var(--spacing-3xl) 0;
  }

  .location-card {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-xl);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    padding: var(--spacing-2xl);
    max-width: 700px;
    margin: 0 auto;
  }

  .location-icon {
    font-size: 40px;
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(201, 168, 76, 0.15);
    border-radius: 12px;
  }

  .location-body h2 {
    color: #ffffff;
    font-size: var(--font-size-xl);
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
  }

  .location-body p {
    color: rgba(255, 255, 255, 0.75);
    font-size: var(--font-size-base);
    line-height: 1.7;
    margin-bottom: var(--spacing-lg);
  }

  .location-body strong {
    color: #ffffff;
  }

  .location-btn {
    display: inline-block;
    padding: 12px 28px;
    border: 2px solid #c9a84c;
    color: #c9a84c;
    font-weight: 700;
    font-size: var(--font-size-sm);
    border-radius: 50px;
    text-decoration: none;
    transition: background 250ms ease, color 250ms ease, transform 200ms ease;
  }

  .location-btn:hover {
    background: #c9a84c;
    color: #1e2a4a;
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    .location-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
