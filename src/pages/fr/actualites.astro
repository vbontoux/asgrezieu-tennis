---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../components/animations/ScrollReveal.astro';

const locale = 'fr';
---

<BaseLayout
  title="Actualités et Événements - Grézieu Tennis"
  description="Actualités du Tennis Club de Grézieu-la-Varenne. Tournois, événements et nouveautés."
  locale={locale}
  currentPath="/fr/actualites"
>
  <div class="page-dark">
    <section class="section">
      <div class="container">
        <ScrollReveal animation="fade-in">
          <div class="section-header">
            <h1>Actualités du Club</h1>
            <div class="title-separator"></div>
          </div>
        </ScrollReveal>

        <div class="news-grid">
          <ScrollReveal animation="slide-up" delay={1}>
            <article class="news-card card-hover">
              <div class="news-badge">🎾 Tournoi</div>
              <h2>Tournoi Open — 2 au 25 avril</h2>
              <p>Cette année, le Tournoi Open revient du 2 au 25 avril !</p>
              <p>Que vous soyez compétiteur ou amateur, venez vous challenger sur les courts dans une ambiance conviviale !</p>
              <p class="news-cta">
                <strong>Inscription et règlement via Ten'Up :</strong><br/>
                <a href="https://tenup.fft.fr/tournoi/189908" target="_blank" rel="noopener noreferrer" class="news-link">
                  tenup.fft.fr/tournoi/189908 →
                </a>
              </p>
              <p class="news-footer">On vous attend nombreux !</p>
            </article>
          </ScrollReveal>

          <ScrollReveal animation="slide-up" delay={2}>
            <article class="news-card card-hover">
              <div class="news-badge">🎾 Nouveau</div>
              <h2>Location de terrains ouverte à tous</h2>
              <p>Le Club ouvre désormais la location horaire de ses terrains aux non-adhérents et non-licenciés !</p>
              <p class="news-cta">
                <strong>Réservez sur Anybuddy :</strong><br/>
                <a href="https://www.anybuddyapp.com/club-grezieu-tennis-as/reservation/tennis?activity=tennis" target="_blank" rel="noopener noreferrer" class="news-link">
                  anybuddyapp.com — Réserver un court →
                </a>
              </p>
            </article>
          </ScrollReveal>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style is:global>body:has(.page-dark){background-color:#1e2a4a;}</style>
<style>
  .page-dark { background-color: #1e2a4a; padding-top: var(--spacing-xl); padding-bottom: var(--spacing-3xl); }
  .section { padding: var(--spacing-2xl) 0; }
  .section-header { text-align: center; margin-bottom: var(--spacing-2xl); }
  .section-header h1 { color: #ffffff; font-size: clamp(28px, 4vw, 44px); font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin-bottom: var(--spacing-md); }
  .title-separator { width: 80px; height: 3px; background-color: #c9a84c; margin: 0 auto; }

  .news-grid { display: grid; grid-template-columns: 1fr; gap: var(--spacing-xl); max-width: 800px; margin: 0 auto; }

  .news-card { background: #ffffff; border-radius: 12px; padding: var(--spacing-2xl); box-shadow: 0 4px 24px rgba(0,0,0,.2); border-left: 5px solid var(--color-primary); }
  .news-badge { display: inline-block; font-size: var(--font-size-sm); font-weight: 600; color: var(--color-primary); margin-bottom: var(--spacing-md); }
  .news-card h2 { font-size: var(--font-size-xl); color: #1e2a4a; margin-bottom: var(--spacing-md); }
  .news-card p { font-size: var(--font-size-base); color: var(--color-text); line-height: 1.7; margin-bottom: var(--spacing-sm); }
  .news-cta { margin-top: var(--spacing-md); padding: var(--spacing-md); background: var(--color-background-alt); border-radius: var(--border-radius); }
  .news-link { color: var(--color-primary); font-weight: 600; word-break: break-all; }
  .news-link:hover { color: var(--color-secondary); }
  .news-footer { font-weight: 600; color: var(--color-primary); margin-top: var(--spacing-md); }
</style>
