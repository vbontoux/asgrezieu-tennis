---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../components/animations/ScrollReveal.astro';
import { asset } from '../../i18n/utils';

const locale = 'en';

const bureau = [
  { name: 'BONTOUX\nRomain', role: 'President', email: 'romain.bontoux@asgrezieutennis.com', photo: asset('/images/board/romain-bontoux.jpg') },
  { name: 'JACOUTON\nCyril', role: 'Vice-President', email: 'cyril.jacouton@asgrezieutennis.com', photo: asset('/images/board/cyril-jacouton.jpg') },
];

const bureauAutres = [
  { name: 'QUINTANA\nSylvie', role: 'Treasurer', email: 'sylvie.quintana@asgrezieutennis.com', photo: asset('/images/board/sylvie-quintana.jpg') },
  { name: 'SIMARD\nThierry', role: 'Assistant Treasurer', email: 'thierry.simard@asgrezieutennis.com', photo: asset('/images/board/thierry-simard.jpg') },
  { name: 'HAUMONT\nNathalie', role: 'Secretary', email: 'nathalie.haumont@asgrezieutennis.com', photo: asset('/images/board/nathalie-haumont.jpg') },
  { name: 'BOURDEAU\nFranck', role: 'Assistant Secretary', email: 'franck.bourdeau@asgrezieutennis.com', photo: asset('/images/board/franck-bourdeau.jpg') },
];

const membres = [
  { name: 'BONTOUX\nAndéol', role: 'Communication', email: 'andeol.bontoux@asgrezieutennis.com', photo: asset('/images/board/andeol-bontoux.jpg') },
  { name: 'LOCATELLI\nLou', role: 'Communication', email: 'lou.locatelli@asgrezieutennis.com', photo: asset('/images/board/lou-locatelli.jpg') },
  { name: 'LAGARDE\nPatrice', role: 'Sponsors', email: 'patrice.lagarde@asgrezieutennis.com', photo: asset('/images/board/patrice-lagarde.jpg') },
  { name: 'LEBAYLE\nFlorent', role: 'Sponsors', email: 'florent.lebayle@asgrezieutennis.com', photo: asset('/images/board/florent-lebayle.jpg') },
  { name: 'REY\nMuriel', role: 'Women\'s Teams Manager', email: 'muriel.rey@asgrezieutennis.com', photo: asset('/images/board/muriel-rey.jpg') },
  { name: 'GALMICHE\nCédric', role: 'Men\'s Teams Manager', email: 'cedric.galmiche@asgrezieutennis.com', photo: asset('/images/board/cedric-galmiche.jpg') },
  { name: 'BRILLANT\nArnaud', role: 'City Hall Relations', email: 'arnaud.brillant@asgrezieutennis.com', photo: asset('/images/board/arnaud-brillant.jpg') },
  { name: 'COCCONCELLI\nDenis', role: 'Utility Player', email: 'denis.cocconcelli@asgrezieutennis.com', photo: asset('/images/board/denis-cocconcelli.jpg') },
  { name: 'HUNAULT\nFabien', role: 'Tournament Committee', email: 'fabien.hunault@asgrezieutennis.com', photo: asset('/images/board/fabien-hunault.jpg') },
  { name: 'VADUREL\nFrancis', role: 'IT Manager', email: 'francis.vadurel@asgrezieutennis.com', photo: asset('/images/board/francis-vadurel.jpg') },
];
---

<BaseLayout
  title="Board of Directors - Grézieu Tennis"
  description="Discover the management team of the Tennis Club of Grézieu-la-Varenne, season 2025/2026."
  locale={locale}
  currentPath="/en/board"
>
  <div class="page-dark">
    <section class="section">
      <div class="container">
        <ScrollReveal animation="fade-in">
          <div class="section-header">
            <h1>The Board<br/>Season 2025/2026</h1>
            <div class="title-separator"></div>
          </div>
        </ScrollReveal>
        <div class="direction-grid">
          {bureau.map((member, i) => (
            <ScrollReveal animation="scale-in" delay={((i + 1) as 1 | 2)}>
              <article class="member-card card-hover">
                <div class="photo-wrapper"><img src={member.photo} alt={`Photo of ${member.name.replace('\n', ' ')}`} width="200" height="200" loading="lazy" /></div>
                <h2 class="member-name" set:html={member.name.replace('\n', '<br/>')} />
                <p class="member-role">{member.role}</p>
                <a href={`mailto:${member.email}`} class="member-email">{member.email}</a>
              </article>
            </ScrollReveal>
          ))}
        </div>
        <div class="bureau-grid">
          {bureauAutres.map((member, i) => (
            <ScrollReveal animation="scale-in" delay={((i % 4 + 1) as 1 | 2 | 3 | 4)}>
              <article class="member-card card-hover">
                <div class="photo-wrapper"><img src={member.photo} alt={`Photo of ${member.name.replace('\n', ' ')}`} width="200" height="200" loading="lazy" /></div>
                <h2 class="member-name" set:html={member.name.replace('\n', '<br/>')} />
                <p class="member-role">{member.role}</p>
                <a href={`mailto:${member.email}`} class="member-email">{member.email}</a>
              </article>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>
    <section class="section">
      <div class="container">
        <ScrollReveal animation="fade-in">
          <div class="section-header">
            <h2 class="section-title-white">Members<br/>Season 2025/2026</h2>
            <div class="title-separator"></div>
          </div>
        </ScrollReveal>
        <div class="membres-grid">
          {membres.map((member, i) => (
            <ScrollReveal animation="scale-in" delay={((i % 4 + 1) as 1 | 2 | 3 | 4)}>
              <article class="member-card card-hover">
                <div class="photo-wrapper"><img src={member.photo} alt={`Photo of ${member.name.replace('\n', ' ')}`} width="200" height="200" loading="lazy" /></div>
                <h3 class="member-name" set:html={member.name.replace('\n', '<br/>')} />
                <p class="member-role">{member.role}</p>
                <a href={`mailto:${member.email}`} class="member-email">{member.email}</a>
              </article>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style is:global>body:has(.page-dark){background-color:#1e2a4a;}</style>
<style>
  .page-dark{background-color:#1e2a4a;padding-top:var(--spacing-xl);padding-bottom:var(--spacing-3xl)}
  .section{padding:var(--spacing-2xl) 0}
  .section-header{text-align:center;margin-bottom:var(--spacing-3xl)}
  .section-header h1,.section-title-white{color:#fff;font-size:clamp(28px,4vw,44px);font-weight:800;text-transform:uppercase;letter-spacing:1px;line-height:1.2;margin-bottom:var(--spacing-md)}
  .title-separator{width:80px;height:3px;background-color:#c9a84c;margin:0 auto}
  .direction-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:var(--spacing-xl);max-width:620px;margin:0 auto var(--spacing-xl)}
  .bureau-grid,.membres-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:var(--spacing-xl);max-width:1000px;margin:0 auto}
  .member-card{text-align:center;padding:var(--spacing-xl) var(--spacing-lg);background:#fff;border-radius:12px;box-shadow:0 4px 24px rgba(0,0,0,.2)}
  .photo-wrapper{width:150px;height:150px;margin:0 auto var(--spacing-lg);border-radius:50%;overflow:hidden;box-shadow:0 4px 16px rgba(0,0,0,.25);border:4px solid #f0f0f0}
  .photo-wrapper img{width:100%;height:100%;object-fit:cover}
  .member-name{font-size:var(--font-size-lg);font-weight:800;color:#1e2a4a;text-transform:uppercase;letter-spacing:.5px;margin-bottom:var(--spacing-xs);line-height:1.3}
  .member-role{font-size:var(--font-size-sm);color:var(--color-text-light);margin-bottom:var(--spacing-sm)}
  .member-email{font-size:12px;color:var(--color-primary);word-break:break-all;transition:color 200ms ease}
  .member-email:hover{color:var(--color-secondary)}
  @media(max-width:600px){.direction-grid{grid-template-columns:1fr;max-width:300px}}
</style>
