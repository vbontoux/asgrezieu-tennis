---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../components/animations/ScrollReveal.astro';
import { asset } from '../../i18n/utils';

const locale = 'en';

// Roles translated to English
const roleTranslations: Record<string, string> = {
  'Président': 'President',
  'Vice-Président': 'Vice-President',
  'Trésorière': 'Treasurer',
  'Trésorier Adjoint': 'Assistant Treasurer',
  'Secrétaire': 'Secretary',
  'Secrétaire Adjoint': 'Assistant Secretary',
  'Communication': 'Communication',
  'Sponsors': 'Sponsors',
  'Responsable équipes femmes': "Women's Teams Manager",
  'Responsable équipes hommes': "Men's Teams Manager",
  'Relation Mairie': 'City Hall Relations',
  'Goal volant': 'Utility Player',
  'Commission Tournoi': 'Tournament Committee',
  'Responsable Informatique': 'IT Manager',
};

const modules = import.meta.glob('../../../content/conseil/*.md', { eager: true });
const sorted = (Object.values(modules) as any[])
  .map(m => ({ ...m.frontmatter, role: roleTranslations[m.frontmatter.role] ?? m.frontmatter.role }))
  .sort((a: any, b: any) => (a.ordre ?? 99) - (b.ordre ?? 99));

const direction    = sorted.filter(m => m.categorie === 'direction');
const bureauAutres = sorted.filter(m => m.categorie === 'bureau');
const membres      = sorted.filter(m => m.categorie === 'membre');
---

<BaseLayout
  title="Board of Directors - Grézieu Tennis"
  description="Discover the management team of the Tennis Club of Grézieu-la-Varenne, season 2025/2026."
  locale={locale}
  currentPath="/en/board"
>
  <div class="page-dark">
    <section class="section">
      <div class="container">
        <ScrollReveal animation="fade-in">
          <div class="section-header">
            <h1>The Board<br/>Season 2025/2026</h1>
            <div class="title-separator"></div>
          </div>
        </ScrollReveal>
        <div class="direction-grid">
          {direction.map((member, i) => (
            <ScrollReveal animation="scale-in" delay={((i + 1) as 1 | 2)}>
              <article class="member-card card-hover">
                <div class="photo-wrapper"><img src={asset(member.photo)} alt={`Photo of ${member.prenom} ${member.nom}`} width="200" height="200" loading="lazy" /></div>
                <h2 class="member-name">{member.nom}<br/>{member.prenom}</h2>
                <p class="member-role">{member.role}</p>
                <a href={`mailto:${member.email}`} class="member-email">{member.email}</a>
              </article>
            </ScrollReveal>
          ))}
        </div>
        <div class="bureau-grid">
          {bureauAutres.map((member, i) => (
            <ScrollReveal animation="scale-in" delay={((i % 4 + 1) as 1 | 2 | 3 | 4)}>
              <article class="member-card card-hover">
                <div class="photo-wrapper"><img src={asset(member.photo)} alt={`Photo of ${member.prenom} ${member.nom}`} width="200" height="200" loading="lazy" /></div>
                <h2 class="member-name">{member.nom}<br/>{member.prenom}</h2>
                <p class="member-role">{member.role}</p>
                <a href={`mailto:${member.email}`} class="member-email">{member.email}</a>
              </article>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>
    <section class="section">
      <div class="container">
        <ScrollReveal animation="fade-in">
          <div class="section-header">
            <h2 class="section-title-white">Members<br/>Season 2025/2026</h2>
            <div class="title-separator"></div>
          </div>
        </ScrollReveal>
        <div class="membres-grid">
          {membres.map((member, i) => (
            <ScrollReveal animation="scale-in" delay={((i % 4 + 1) as 1 | 2 | 3 | 4)}>
              <article class="member-card card-hover">
                <div class="photo-wrapper"><img src={asset(member.photo)} alt={`Photo of ${member.prenom} ${member.nom}`} width="200" height="200" loading="lazy" /></div>
                <h3 class="member-name">{member.nom}<br/>{member.prenom}</h3>
                <p class="member-role">{member.role}</p>
                <a href={`mailto:${member.email}`} class="member-email">{member.email}</a>
              </article>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style is:global>body:has(.page-dark){background-color:#1e2a4a;}</style>
<style>
  .page-dark{background-color:#1e2a4a;padding-top:var(--spacing-xl);padding-bottom:var(--spacing-3xl)}
  .section{padding:var(--spacing-2xl) 0}
  .section-header{text-align:center;margin-bottom:var(--spacing-3xl)}
  .section-header h1,.section-title-white{color:#fff;font-size:clamp(28px,4vw,44px);font-weight:800;text-transform:uppercase;letter-spacing:1px;line-height:1.2;margin-bottom:var(--spacing-md)}
  .title-separator{width:80px;height:3px;background-color:#c9a84c;margin:0 auto}
  .direction-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:var(--spacing-xl);max-width:620px;margin:0 auto var(--spacing-xl)}
  .bureau-grid,.membres-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:var(--spacing-xl);max-width:1000px;margin:0 auto}
  .member-card{text-align:center;padding:var(--spacing-xl) var(--spacing-lg);background:#fff;border-radius:12px;box-shadow:0 4px 24px rgba(0,0,0,.2)}
  .photo-wrapper{width:150px;height:150px;margin:0 auto var(--spacing-lg);border-radius:50%;overflow:hidden;box-shadow:0 4px 16px rgba(0,0,0,.25);border:4px solid #f0f0f0}
  .photo-wrapper img{width:100%;height:100%;object-fit:cover}
  .member-name{font-size:var(--font-size-lg);font-weight:800;color:#1e2a4a;text-transform:uppercase;letter-spacing:.5px;margin-bottom:var(--spacing-xs);line-height:1.3}
  .member-role{font-size:var(--font-size-sm);color:var(--color-text-light);margin-bottom:var(--spacing-sm)}
  .member-email{font-size:12px;color:var(--color-primary);word-break:break-all;transition:color 200ms ease}
  .member-email:hover{color:var(--color-secondary)}
  @media(max-width:600px){.direction-grid{grid-template-columns:1fr;max-width:300px}}
</style>
